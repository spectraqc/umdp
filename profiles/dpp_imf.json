{
  "id": "dpp_imf",
  "name": "DPP IMF — UK Broadcast IMF Delivery",
  "delivery_paradigm": "imf",
  "content_type": "program",
  "governance": {
    "spec_version": "1.1",
    "effective_date": "2026-01-01",
    "source": "DPP IMF Application — UK Broadcast Delivery",
    "sourceAccess": "portal-login",
    "jurisdiction": ["GB"],
    "notes": "Illustrative DPP-style IMF profile demonstrating UMDP 0.8.0 region-typed routing. IMF (SMPTE ST 2067) package with a CPL whose markers (FFOA/LFOA) authoritatively bound the programme; markers are conformance-bearing, so a marker that disagrees with the essence is a FAIL. Test-signal head (bars & tone) is checked as a test signal, not against programme-content artefact tests."
  },
  "assets": {
    "video": {
      "codec": { "allowed": ["jpeg2000"] },
      "container": { "allowed": ["mxf"] },
      "resolution": { "allowed": ["1920x1080"] },
      "frame_rate": { "mode": "fixed", "allowed": ["25"] },
      "scan_type": ["progressive"],
      "color": {
        "primaries": ["bt709"],
        "transfer": ["bt709"],
        "matrix": ["bt709"],
        "range": ["limited"]
      },
      "bit_depth": { "allowed": [10] },
      "chroma_subsampling": ["4:2:2"],
      "quality": {
        "colour_bars": { "mode": "required_head", "window_s": 30 }
      }
    },
    "audio": {
      "codec": { "allowed": ["pcm_s24le"] },
      "sample_rate": [48000],
      "bit_depth": { "allowed": [24] },
      "track_count": { "min": 2, "max": 16 },
      "loudness": {
        "standards": [{ "name": "EBU R128", "target": -23.0, "tolerance": 0.5 }],
        "true_peak_max": -1.0
      }
    }
  },
  "structure": {
    "type": "timeline",
    "timeline": { "timecode_start": "10:00:00:00" }
  },
  "segmentation": {
    "source": "cpl_markers",
    "markers_conformance_bearing": true,
    "region_checks": {
      "bars_and_tone": ["video_colour_bars", "audio_quasi_peak"],
      "slate_clock": ["content_slate_fields"]
    }
  }
}
